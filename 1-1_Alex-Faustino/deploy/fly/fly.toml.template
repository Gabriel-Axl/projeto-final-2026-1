# fly.toml template — replace APP_NAME and region before using
app = "APP_NAME"

[build]
  image = ""

[env]
  # Example env vars; set these via `flyctl secrets set` in production
  PREDICT_API_KEY = "changeme"
  METRICS_PERSIST_PATH = "/data/metrics_history.jsonl"

[[mounts]]
  source = "metrics_volume"
  destination = "/data"

[experimental]
  allowed_public_ports = [8000]
  auto_rollback = true
