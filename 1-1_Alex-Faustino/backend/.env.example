# LLM Configuration
GEMINI_API_KEY=your-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_COST_PER_CALL=0.0

# Metrics
METRICS_PERSIST_PATH=metrics_history.jsonl
PERSIST_INTERVAL_SECONDS=1800

# API Authentication
PREDICT_API_KEY=change-me
# Frontend user credentials (dev only)
FRONTEND_USER=admin
FRONTEND_PASSWORD=change-me
# JWT secret used to sign frontend tokens
SECRET_KEY=change-me-secret